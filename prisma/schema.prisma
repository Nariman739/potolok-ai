generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH
// ============================================

model Master {
  id              String   @id @default(uuid())
  phone           String   @unique
  email           String?  @unique
  passwordHash    String

  // Profile
  firstName       String
  lastName        String?
  companyName     String?

  // Branding (for KP PDFs)
  logoUrl         String?
  brandColor      String   @default("#1e3a5f")
  instagramUrl    String?
  whatsappPhone   String?
  address         String?

  // Telegram integration
  telegramChatId   String?  @unique
  telegramLinkCode String?  @unique  // temp code for /start deep link

  // Password reset OTP (sent via Telegram)
  resetOtp          String?
  resetOtpExpiresAt DateTime?

  // Contract settings
  contractType      String?  // "ip" | "individual" | null
  bin               String?  // БИН (для ИП)
  iin               String?  // ИИН (для физлица)
  legalName         String?  // Полное ФИО / наименование ИП
  legalAddress      String?  // Юридический адрес
  bankName          String?  // Название банка
  iban              String?  // IBAN (расчётный счёт)
  kbe               String?  // КБе (код бенефициара)
  bik               String?  // БИК банка
  passportData      String?  // Серия/номер удостоверения (для физлица)
  prepaymentPercent Int      @default(50)
  warrantyMaterials Int      @default(10)
  warrantyInstall   Int      @default(2)
  contractCity      String?

  // Subscription
  subscriptionTier SubscriptionTier @default(FREE)
  kpGeneratedThisMonth Int  @default(0)
  kpMonthReset    DateTime @default(now())

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prices          MasterPrice[]
  estimates       Estimate[]
  sessions        Session[]
  chatSessions    ChatSession[]
  customItems     CustomItem[]
  portfolioWorks  PortfolioWork[]
  measurements    MeasurementObject[]

  // Portfolio
  portfolioSlug   String?  @unique  // e.g. "ivan-almaty" → potolok.ai/master/ivan-almaty
  portfolioBio    String?            // Краткое описание мастера для публичной страницы
}

model Session {
  id          String   @id @default(uuid())
  masterId    String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  master      Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)
}

enum SubscriptionTier {
  FREE
  PRO
}

// ============================================
// PRICING
// ============================================

model MasterPrice {
  id          String @id @default(uuid())
  masterId    String
  itemCode    String
  price       Float

  master      Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([masterId, itemCode])
}

// ============================================
// CUSTOM ITEMS (per-master custom price positions)
// ============================================

model CustomItem {
  id        String   @id @default(uuid())
  masterId  String
  code      String
  name      String
  unit      String   // "м²" | "м.п." | "шт."
  price     Float
  category  String   @default("custom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  master    Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([masterId, code])
}

// ============================================
// ESTIMATES
// ============================================

model Estimate {
  id              String   @id @default(uuid())
  publicId        String   @unique @default(uuid())
  masterId        String

  // Client info
  clientName      String?
  clientPhone     String?
  clientAddress   String?

  // Data (JSON)
  roomsData       Json
  calculationData Json

  // Summary
  totalArea       Float
  total           Float    @default(0)
  discountPercent Float    @default(0)
  economyTotal    Float?
  standardTotal   Float?
  premiumTotal    Float?

  // Status
  status          EstimateStatus @default(DRAFT)

  // Variant selection
  recommendedVariant String?  // "economy" | "standard" | "premium" — master sets this
  confirmedVariant   String?  // which variant the client chose when confirming

  // PDF
  pdfUrl          String?

  // Timestamps
  validUntil      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chatSession     ChatSession?

  master          Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)
}

enum EstimateStatus {
  DRAFT
  SENT
  VIEWED
  CONFIRMED
  REJECTED
  REVISED     // Мастер пересмотрел — старое КП недействительно, не считается в аналитике
}

// ============================================
// CHAT / ASSISTANT
// ============================================

model ChatSession {
  id              String      @id @default(uuid())
  masterId        String
  messages        Json        @default("[]")
  photoUrls       String[]    @default([])
  extractedRooms  Json?
  calculationData Json?
  estimateId      String?     @unique
  status          ChatStatus  @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  estimate        Estimate?   @relation(fields: [estimateId], references: [id])
  master          Master      @relation(fields: [masterId], references: [id], onDelete: Cascade)
}

enum ChatStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// ============================================
// PORTFOLIO
// ============================================

// ============================================
// MEASUREMENTS (замеры объектов)
// ============================================

model MeasurementObject {
  id          String   @id @default(uuid())
  masterId    String
  address     String   @default("")
  totalArea   Float    @default(0)
  status      String   @default("active")  // "active" | "saved"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms       MeasurementRoom[]
  master      Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([masterId, status])
  @@index([masterId, createdAt])
}

model MeasurementRoom {
  id             String   @id @default(uuid())
  objectId       String
  name           String   @default("")
  walls          Json     // number[] — длины стен в см
  normalCorners  Json     // boolean[] — тип углов
  area           Float
  perimeter      Float
  elements       Json     @default("[]")  // RoomElement[] — софиты, люстры, гардины и т.д.
  sortOrder      Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  object         MeasurementObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
}

// ============================================
// PORTFOLIO
// ============================================

model PortfolioWork {
  id            String   @id @default(uuid())
  masterId      String

  title         String?            // "Двухуровневый потолок в гостиной"
  description   String?            // Свободное описание
  ceilingType   String?            // "матовый" | "глянцевый" | "сатин" | "двухуровневый"
  area          Float?             // Площадь в м²
  photos        String[]  @default([])  // URLs из Vercel Blob
  videoUrl      String?            // Ссылка на видео (YouTube/Vercel Blob)

  isPublished   Boolean  @default(true)
  sortOrder     Int      @default(0)   // Для ручной сортировки

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  master        Master   @relation(fields: [masterId], references: [id], onDelete: Cascade)
}
