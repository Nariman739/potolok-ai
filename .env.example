# Database — Neon PostgreSQL (use pooler endpoint)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# OpenRouter AI — for Claude Sonnet via OpenRouter
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxx

# Telegram Bot — webhook-based bot for measurements
# Create bot via @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCxxx

# Vercel Blob — image/file storage
# Auto-provided on Vercel, or create at https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Groq — voice message transcription (STT)
# Get key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx

# Instagram OAuth — server-only HMAC secret for signed state tokens
# Generate with: openssl rand -base64 48
INSTAGRAM_STATE_SECRET=replace-with-48-random-bytes-base64

# Telegram webhook — required header secret (Telegram x-telegram-bot-api-secret-token).
# Generate with: openssl rand -base64 32 and set the same value on the webhook via
# setWebhook?secret_token=...
TELEGRAM_WEBHOOK_SECRET=replace-with-32-random-bytes
